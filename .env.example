# Copy to .env (auto-loaded by docker-compose and run.sh).
# Don't commit a real .env — secrets only belong in your shell or your
# hosting panel.

# ---- MySQL ----
DB_NAME=bodhassess
DB_USERNAME=bodh
DB_PASSWORD=bodh
DB_ROOT_PASSWORD=rootpw
DB_PORT=3306

# ---- Spring API ----
APP_PORT=4000
APP_AUTH_TOKEN_SECRET=change-me-to-a-long-random-hex-string
APP_AUTH_TOKEN_EXPIRATION_MSEC=604800000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_UPLOADS_BASE_URL=http://localhost:4000

# ---- Admin login (single account, env-driven) ----
# POST /api/v1/admin/login  {"username":"admin","password":"admin123"}
# Override APP_ADMIN_PASSWORD in production with a strong value.
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123

# ---- Vite frontend ----
WEB_PORT=3000
# Baked into the bundle at build time. For prod-on-localhost keep this as-is;
# for a real deploy point it at the public API URL (e.g. https://api.bodh.biz/api/v1).
VITE_API_URL=http://localhost:4000/api/v1
VITE_BASE_PATH=/
VITE_APP_NAME=BodhAssess
