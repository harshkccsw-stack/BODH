# Copy to .env.local for development, or set these in your hosting panel
# for production. Only NEXT_PUBLIC_* vars reach the browser.

NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_NAME=BodhAssess
NEXT_PUBLIC_AUTH_STORAGE_KEY=bodhassess.auth.token

# Optional: set only if the app is mounted under a sub-path.
# NEXT_PUBLIC_BASE_PATH=/bodh
