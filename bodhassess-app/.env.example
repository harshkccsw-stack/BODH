# Copy to .env.local for development, or set these in your hosting panel
# for production. Only VITE_* vars reach the browser.

VITE_API_URL=https://api.bodh.biz/api/v1
VITE_APP_NAME=BodhAssess
VITE_AUTH_STORAGE_KEY=bodhassess.auth.token

# Frontend is served from https://admin.bodh.biz/dashboard in production,
# so the bundle must be built with VITE_BASE_PATH=/dashboard. Leave unset
# (or "/") for local dev served from the root.
VITE_BASE_PATH=/dashboard
