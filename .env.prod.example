# Copy to .env.prod on the droplet and fill in real values.
# docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# DigitalOcean Container Registry, e.g. registry.digitalocean.com/bodh
DOCR_REGISTRY=registry.digitalocean.com/CHANGEME
IMAGE_TAG=latest

# Postgres
DB_USER=bodh
DB_PASSWORD=CHANGEME
DB_NAME=bodhassess

# MinIO
MINIO_ROOT_USER=bodhminio
MINIO_ROOT_PASSWORD=CHANGEME

# JWT
JWT_SECRET=CHANGEME

# Caddy / TLS
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
