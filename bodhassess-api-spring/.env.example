# Copy to .env (read by docker-compose automatically) for prod mode.
# Dev mode reads these from your shell environment.

# ---- MySQL ----
DB_NAME=bodhassess
DB_USERNAME=bodh
DB_PASSWORD=bodh
DB_ROOT_PASSWORD=rootpw
DB_PORT=3306

# ---- Redis (heartbeat / live tracking) ----
# REDIS_PORT is the host-side port we publish (Redis inside the container always listens on 6379).
# Dev mode: Spring runs on the host, so REDIS_HOST=localhost.
# Prod mode (compose): docker-compose overrides REDIS_HOST=redis, REDIS_PORT=6379 internally.
REDIS_HOST=localhost
REDIS_PORT=6390

# ---- App ----
APP_PORT=4000
# Generate a 64+ char hex secret for production. NEVER commit a real one.
APP_AUTH_TOKEN_SECRET=change-me-to-a-long-random-hex-string
APP_AUTH_TOKEN_EXPIRATION_MSEC=604800000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
APP_UPLOADS_BASE_URL=http://localhost:4000

# ---- Admin login (single account, env-driven) ----
# POST /api/v1/admin/login  {"username":"admin","password":"admin123"}
# Override APP_ADMIN_PASSWORD in production with a strong value.
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123
