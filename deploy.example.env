# Copy this to deploy.production.env or deploy.staging.env (both gitignored)
# and fill in the values for that environment.

# SSH target — user@host. Must be set up so `ssh $REMOTE_HOST` works without
# a password prompt (SSH key in agent or referenced via ~/.ssh/config).
REMOTE_HOST=deploy@api.example.com

# Where to drop the compiled Go binary on the remote.
API_REMOTE_PATH=/opt/bodh/bin/server

# Where to drop the built dist/ on the remote (served by nginx/caddy).
WEB_REMOTE_PATH=/var/www/bodh

# Command run on remote (via ssh) after the binary is uploaded.
# Pick one that matches how the server is supervised:
#   sudo systemctl restart bodh-api
#   docker compose -f /opt/bodh/docker-compose.yml restart api
#   pkill -HUP server
API_RESTART_CMD=sudo systemctl restart bodh-api

# Optional: command to apply DB migrations before restarting the API.
# Leave blank to skip. Example:
#   docker compose exec -T postgres psql -U bodh -d bodhassess -f /migrations/latest.sql
# MIGRATE_CMD=

# Optional: command to reload the web server after dist/ uploads (clears any
# in-memory caches). Leave blank if your server picks up changes from disk
# directly.
#   sudo systemctl reload nginx
#   docker compose exec caddy caddy reload --config /etc/caddy/Caddyfile
# WEB_RELOAD_CMD=

# Build-time env baked into the JS bundle.
VITE_API_URL=https://api.example.com/api/v1
# VITE_APP_NAME=BodhAssess
# VITE_AUTH_STORAGE_KEY=bodhassess.auth.token

# Optional smoke tests run after deploy. Leave blank to skip.
HEALTH_URL=https://api.example.com/api/v1/health
WEB_URL=https://app.example.com/
